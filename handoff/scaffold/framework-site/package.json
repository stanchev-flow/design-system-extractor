    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "style-dictionary": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-singlefile": "^2.1.0"
  }
