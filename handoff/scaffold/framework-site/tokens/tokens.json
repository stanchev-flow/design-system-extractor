{
  "$description": "Design tokens for grounded_service_growth_system. SOURCE-GROUNDED build: color + font values are read from the live Hatch CSS (screenshots/hackathon-test/source/source-colors.json) via the live-source pipeline, NOT inferred from the screenshot. Spacing/radius/type roles still come from the screenshot extraction (design-system.md) where the source had no clean token. This is the single source of truth; Style Dictionary compiles it to the Tailwind v4 @theme and could equally emit Webflow Variables.",
  "color": {
    "$type": "color",
    "$description": "Exact literals/variables from Hatch source CSS. Provenance noted per token.",
    "surface": {
      "primary": { "$value": "#ffffff" },
      "secondary": { "$value": "#f5f7f6", "$extensions": { "source": "--_theme---background-slate" } },
      "inverse": { "$value": "#0f281b", "$extensions": { "source": "--_button-style---text (brand deep green)" } },
      "soft": { "$value": "#d7e2dd", "$extensions": { "source": "derived sage tint (no explicit source var)" } },
      "media": { "$value": "#20211f", "$extensions": { "source": "screenshot-derived media dark" } }
    },
    "text": {
      "primary": { "$value": "#212d3a", "$extensions": { "source": "rgb(33,45,58), most frequent body dark" } },
      "muted": { "$value": "#5b665d" },
      "on-inverse": { "$value": "#f4f6f3" },
      "on-inverse-muted": { "$value": "#9ab7b2", "$extensions": { "source": "--_theme---button-play-footer surface (sage)" } },
      "on-media": { "$value": "#ffffff" },
      "accent-on-inverse": { "$value": "#9ab7b2" }
    },
    "border": {
      "hairline": { "$value": "#e3e2dc" },
      "on-inverse": { "$value": "rgba(255,255,255,0.16)", "$extensions": { "source": "--_theme---border-transparent--brand color-mix" } },
      "field": { "$value": "#d9ddd6" }
    },
    "accent": {
      "primary": { "$value": "#0f281b", "$extensions": { "source": "--_button-style---text / brand deep green" } },
      "on-accent": { "$value": "#ffffff" },
      "secondary": { "$value": "#2b4539", "$extensions": { "source": "--_theme---button-secondary--background" } },
      "secondary-hover": { "$value": "#2c5e44", "$extensions": { "source": "--_theme---button-secondary--background-hover" } },
      "highlight-on-dark": { "$value": "#9ab7b2" }
    },
    "graphic": {
      "star-rating": { "$value": "#faae7a", "$extensions": { "source": "--_theme---border--orange" } },
      "info-blue": { "$value": "#c1d7ff", "$extensions": { "source": "--_theme---border--blue" } },
      "logo-muted": { "$value": "#959494", "$extensions": { "source": "rgb(149,148,148)" } }
    }
  },
  "font": {
    "$type": "fontFamily",
    "$description": "Real @font-face families downloaded from Hatch source CSS: Instrument Sans (SemiCondensed/Condensed, weights 400/600/700). No substitution.",
    "heading": { "$value": ["Instrument Sans", "Georgia", "sans-serif"] },
    "body": { "$value": ["Instrument Sans", "Georgia", "sans-serif"] }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "8px" },
    "md": { "$value": "12px" },
    "lg": { "$value": "16px" },
    "panel": { "$value": "20px" },
    "pill": { "$value": "999px" }
  },
  "shadow": {
    "$type": "shadow",
    "floating-card": { "$value": "0 8px 24px rgba(20,30,24,0.12)" }
  },
  "space": {
    "$type": "dimension",
    "section-y": { "$value": "96px" },
    "section-y-tight": { "$value": "64px" },
    "stack": { "$value": "16px" },
    "control-x": { "$value": "20px" },
    "control-y": { "$value": "12px" }
  },
  "type": {
    "$description": "Role-based type scale from typography.* — sizes/weights/leading/tracking are normative.",
    "h1": { "size": "56px", "weight": "700", "leading": "1.02", "tracking": "-0.01em" },
    "h2": { "size": "40px", "weight": "700", "leading": "1.05", "tracking": "-0.01em" },
    "h3": { "size": "24px", "weight": "700", "leading": "1.15", "tracking": "-0.005em" },
    "display-metric": { "size": "52px", "weight": "700", "leading": "1.0", "tracking": "-0.01em" },
    "lead": { "size": "16px", "weight": "400", "leading": "1.5", "tracking": "0" },
    "body": { "size": "15px", "weight": "400", "leading": "1.55", "tracking": "0" },
    "quote": { "size": "22px", "weight": "700", "leading": "1.25", "tracking": "-0.005em" },
    "eyebrow": { "size": "12px", "weight": "500", "leading": "1.2", "tracking": "0.08em", "transform": "uppercase" },
    "metadata": { "size": "13px", "weight": "400", "leading": "1.4", "tracking": "0" },
    "control": { "size": "15px", "weight": "500", "leading": "1.2", "tracking": "0" }
  }
}
