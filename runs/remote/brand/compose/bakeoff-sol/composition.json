          "textLen": "medium",
          "sizeClass": "title",
          "width": "hug",
          "z": "front",
          "copy": {
            "eyebrow": "QUESTIONS, ANSWERED",
            "heading": "What leaders ask before a demo",
            "body": "Start with your operating model and the workforce decisions your team needs to make."
          }
        },
        {
          "name": "items",
          "role": "faq disclosure items",
          "contract": "faq-item",
          "textLen": "long",
          "sizeClass": "body",
          "width": "stretch",
          "z": "front",
          "copy": [
            {
              "question": "Who is Workforce Intelligence designed for?",
              "answer": "It is designed for People, Finance, and HR Operations leaders who need a shared view of workforce information for recurring reviews and business decisions."
            },
            {
              "question": "What workforce questions can we bring to a demo?",
              "answer": "Bring a real question your team regularly answers, such as understanding workforce change, preparing a leadership review, or aligning People and Finance around a plan."
            },
            {
              "question": "Does this replace our HR systems?",
              "answer": "The product is positioned as a decision layer for workforce review. A demo can clarify how it fits with the systems and processes your team uses today."
            },
            {
              "question": "Is it relevant for a multi-country workforce?",
              "answer": "The launch is intended for international companies. Share your countries, workforce model, and reporting process so the demo can focus on your operating context."
            },
            {
              "question": "What should we prepare before the demo?",
              "answer": "Your role, approximate company size, operating footprint, and one recurring workforce decision are enough to tailor the conversation."
            }
          ]
        }
      ],
      "treatments": [],
      "knobs": {
        "faq": {
          "exclusive": true,
          "open": 0,
          "activeSurface": "surface/accent",
          "hoverWash": "accent/warm-wash"
        }
      }
