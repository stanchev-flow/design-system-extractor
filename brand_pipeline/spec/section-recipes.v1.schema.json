{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://webflow.dev/brand-pipeline/section-recipes.v1.schema.json",
  "title": "section-recipes.v1",
  "description": "Brand-agnostic section recipe families. Structural identity is separated from ingredient, orientation, media, interaction, and responsive variant axes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "coverage", "recipes"],
  "properties": {
    "schemaVersion": { "const": "section-recipes.v1" },
    "source": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "productRole",
        "storesVendoredSource",
        "ignoredVisualStyle",
        "selectionPrecedence",
        "knownBiases",
        "coverageLimit",
        "genreMergePolicy"
      ],
      "properties": {
        "name": { "type": "string" },
        "kind": { "const": "structural-prior" },
        "productRole": { "const": "content-structure-baseline" },
        "storesVendoredSource": { "const": false },
        "ignoredVisualStyle": {
          "type": "array",
          "contains": { "const": "class-names" },
          "minItems": 1,
          "uniqueItems": true
        },
        "selectionPrecedence": {
          "type": "array",
          "prefixItems": [
            { "const": "active-brand-facts" },
            { "const": "active-style-structure" },
            { "const": "brand-neverDo-and-physics" },
            { "const": "selected-structural-prior" }
          ],
          "items": false
        },
        "knownBiases": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "coverageLimit": { "type": "string", "minLength": 1 },
        "genreMergePolicy": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "coverage": {
      "type": "object",
      "required": [
        "categoryCount",
        "componentCount",
        "recipeFamilyCount",
        "responsiveSourceInspectedRecipeCount",
        "responsiveSourcePendingRecipeCount",
        "categories",
        "recipeFamiliesByCategory",
        "duplicateComponentSlugs"
      ],
      "properties": {
        "categoryCount": { "type": "integer", "minimum": 0 },
        "componentCount": { "type": "integer", "minimum": 0 },
        "recipeFamilyCount": { "type": "integer", "minimum": 0 },
        "responsiveSourceInspectedRecipeCount": { "type": "integer", "minimum": 0 },
        "responsiveSourcePendingRecipeCount": { "type": "integer", "minimum": 0 },
        "categories": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "recipeFamiliesByCategory": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "duplicateComponentSlugs": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "recipes": {
      "type": "array",
      "items": { "$ref": "#/$defs/recipe" }
    }
  },
  "$defs": {
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sectionType",
        "builderUseCase",
        "sourceCategory",
        "structure",
        "slots",
        "variantAxes",
        "responsive",
        "anatomyEvidence",
        "physicsBindings",
        "provenance"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "sectionType": { "type": "string", "minLength": 1 },
        "builderUseCase": { "type": ["string", "null"] },
        "sourceCategory": { "type": "string", "minLength": 1 },
        "structure": {
          "type": "object",
          "additionalProperties": false,
          "required": ["skeleton", "archetype"],
          "properties": {
            "skeleton": { "type": "string", "minLength": 1 },
            "archetype": {
              "enum": ["stack", "split", "cards", "collage", "overlay"]
            }
          }
        },
        "slots": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "optional"],
          "properties": {
            "required": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "optional": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          }
        },
        "variantAxes": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "responsive": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidenceStatus",
            "breakpointModel",
            "orientationIsVariant",
            "rules",
            "inspectedComponentSlugs"
          ],
          "properties": {
            "evidenceStatus": {
              "enum": ["source-inspected", "pending-source-inspection"]
            },
            "breakpointModel": { "const": "mobile-first" },
            "orientationIsVariant": { "type": "boolean" },
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["axis", "base"],
                "additionalProperties": true
              }
            },
            "inspectedComponentSlugs": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          }
        },
        "anatomyEvidence": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        },
        "physicsBindings": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "provenance": {
          "type": "object",
          "required": [
            "source",
            "componentCount",
            "componentSlugs",
            "previewExamples",
            "tags",
            "normalization"
          ],
          "additionalProperties": true
        }
      }
    }
  }
}
