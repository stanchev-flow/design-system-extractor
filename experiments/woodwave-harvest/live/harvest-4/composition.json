          "asset": {
            "src": "About-img-2.jpg",
            "alt": "Timber architecture detail"
          }
        }
      ],
      "treatments": [
        {
          "kind": "ghost-word",
          "target": "ghost",
          "amount": {
            "class": "light"
          }
        },
