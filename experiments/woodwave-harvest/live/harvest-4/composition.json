      "slots": [
        {
          "name": "canvas",
          "role": "background-media",
          "contract": "image",
          "textLen": "none",
          "width": "full-bleed",
          "mediaAspect": "portrait",
          "z": "back",
          "colStart": 1,
          "colSpan": 12,
          "asset": {
            "src": "Web-gallery-1.jpg",
            "alt": "Warm timber gallery interior",
            "ratio": "portrait"
          }
        },
        {
          "name": "statement-card",
          "role": "panel",
          "contract": "content-block",
          "textLen": "short",
          "sizeClass": "display",
          "width": "media",
          "z": "front",
          "colStart": 4,
          "colSpan": 6,
          "copy": {
            "eyebrow": "Woodwave Gallery",
            "heading": "Space as a muse",
            "text": "Contemporary art in a landmark timber building \u2014 from the late 20th century to today.",
            "caption": "About / Gallery / Exhibition / Visit"
          }
        }
      ],
      "treatments": [
        {
          "kind": "bleed",
          "target": "canvas",
          "amount": {
            "class": "heavy"
          }
        },
        {
          "kind": "panel-on-media",
          "target": "statement-card",
          "over": "canvas",
          "distribute": "space-between"
        }
      ],
      "alignment": {
        "anchor": "centered",
        "counterweight": "canvas"
