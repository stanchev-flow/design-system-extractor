  "sections": [
    {
      "id": "hero",
      "useCase": "hero",
      "archetype": "overlay",
      "surfaceIntent": "inverse",
      "novelty": "adapt",
      "seededFrom": {
        "lib": "standard",
        "id": "card-over-portrait-statement"
