          }
        },
        {
          "name": "media-secondary",
          "role": "media-2",
          "contract": "image",
          "width": "media",
          "mediaAspect": "landscape",
          "z": "mid",
          "asset": {
            "src": "overlap-vase.jpg",
            "alt": "A single vessel from the WoodWave collection",
