{
  "layout": "opening-bookend",
  "brand": "WoodWave Gallery",
  "composition_mode": false,
  "neverDo": {
    "no-buttons": true,
    "no-radius": true,
    "no-shadows": true,
    "no-gradients": true,
    "no-cards-on-cream": true,
    "no-accent-on-light": true,
    "no-boxed-inputs": true,
    "no-text-on-photos": true,
    "no-section-hairlines": true,
    "no-default-fonts": true,
    "no-centered-everything": true
  },
  "neverDo_allowed": [],
  "fidelity": {
    "pass": true,
    "checks": {
      "Surface = brand surface/inverse (#3A2F23)": true,
      "Display family present (Melodrama)": true,
      "Heading copy from source present": true,
      "Brand accent surfaced (#E9DC8C)": true,
      "Brand media present (expect ~2)": true,
      "Brand assets present (not placeholder)": true
    }
  },
  "slop": {
    "pass": true,
    "checks": {
      "No default/system display font": true,
      "No off-palette hex colors": true,
      "No lorem/placeholder copy": true,
      "All brand image assets present": true,
      "Rounding matches brand radius scale": true,
      "Webfonts loaded (no silent system fallback)": true
    }
  },
  "invariants": {
    "mode": "advisory",
    "pass": false,
    "checks": {
      "single-accent": false,
      "primitive-only": false,
      "rhythm": false,
      "data-composition": true,
      "slot-resolution": true
    }
  },
  "overall": true
}
