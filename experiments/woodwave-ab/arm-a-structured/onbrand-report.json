      "alignment-resolution": true,
      "media-registration": true,
      "interaction-contrast": true,
      "token-provenance": true,
      "logo-wall-integrity": true
    },
    "details": {
      "text-contrast": "39 text elements measured against their effective background (surface + decoration layer); worst = sec-0/cs-sub('A simpler way to get sta') at 7.19 (floor 4.5); skipped=0",
      "decoration-salience": "1 decoration layer(s) all within the salience ceiling (<= 1.19); loudest = sec-1/cs-ghost('EVERYTHING') at ratio 1.124 (luminance delta 0.1033)"
    }
